{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/server",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*", "prisma/seed.ts"],
  "exclude": ["node_modules", "src", "dist"]
}
