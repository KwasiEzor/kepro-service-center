# --- DATABASE ---
DATABASE_URL="postgresql://user:password@localhost:5432/keypro?schema=public"

# --- AUTHENTICATION ---
JWT_SECRET="your_super_secret_jwt_key_at_least_32_chars"

# --- API KEYS ---
# Required for the backend chatbot service
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: Frontend API Key (only if using direct client-side calls, not recommended for prod)
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# --- URLS ---
FRONTEND_URL="http://localhost:3000"
VITE_API_URL="http://localhost:3001"
PORT=3001

# --- EMAIL (SMTP) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_password"
SMTP_FROM="KeyPro Service Center <noreply@example.com>"
ADMIN_EMAIL="admin@example.com"

# --- UPLOADS ---
# Path relative to project root or absolute path
UPLOAD_DIR="uploads"

# --- DEVELOPMENT ---
# DISABLE_HMR=true # Uncomment to disable HMR in AI Studio
NODE_ENV="development"
