# Backend API Key (server-side only - NEVER expose in client code)
GEMINI_API_KEY="your_gemini_api_key_here"

# Frontend API Key (client-side - only for development/demo)
# For production, use server-side proxy instead
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# App URL (for production deployment)
APP_URL="http://localhost:3000"

# Development Configuration
# Uncomment to disable HMR in AI Studio
# DISABLE_HMR=true
