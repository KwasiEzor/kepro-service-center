# Test Environment Configuration Example
# Copy this to .env.test and update values for your local setup

NODE_ENV=test

# Test Database (separate from development)
# Update username to match your PostgreSQL user
DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/keypro_test?schema=public"

# Test-specific secrets (NOT for production)
JWT_SECRET="test_jwt_secret_minimum_32_characters_long_for_testing"
JWT_REFRESH_SECRET="test_refresh_secret_minimum_32_characters_for_testing"

# Mock external services for tests
GEMINI_API_KEY="test_gemini_api_key_not_real"
VITE_GEMINI_API_KEY="test_gemini_api_key_not_real"

# Test SMTP (Mailtrap or similar)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="test"
SMTP_PASS="test"
SMTP_FROM="KeyPro Test <test@keypro.test>"
ADMIN_EMAIL="admin@keypro.test"

# Test URLs
FRONTEND_URL="http://localhost:3000"
VITE_API_URL="http://localhost:3001"
PORT=3001

# Uploads
UPLOAD_DIR="uploads"

# Logging (suppress in tests)
LOG_LEVEL="error"

# No Sentry in tests
# SENTRY_DSN is intentionally NOT set
